// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum PlatformRole {
  USER
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum WorkspaceStatus {
  ACTIVE
  SUSPENDED
}

enum WorkspaceRole {
  OWNER
  ADMIN
  AGENT
}

enum MemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum ConversationSource {
  WIDGET
  API
  DASHBOARD
}

enum SenderType {
  CUSTOMER
  AI
  AGENT
  SYSTEM
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum WebhookStatus {
  ACTIVE
  DISABLED
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  passwordHash  String?
  fullName      String
  avatarUrl     String?
  googleId      String?      @unique
  authProvider  AuthProvider @default(LOCAL)
  emailVerified Boolean      @default(false)
  platformRole  PlatformRole @default(USER)
  status        UserStatus   @default(ACTIVE)
  lastLoginAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  refreshTokens         RefreshToken[]
  passwordResetTokens   PasswordResetToken[]
  workspaceMembers      WorkspaceMember[]
  sentInvitations       WorkspaceInvitation[]
  apiKeys               ApiKey[]
  uploadedDocuments     Document[]
  assignedConversations Conversation[]
  sentMessages          Message[]
  conversationNotes     ConversationNote[]
  conversationAuditLogs ConversationAuditLog[]
  fcmTokens             AgentFcmToken[]

  @@index([email])
  @@index([googleId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model Workspace {
  id        String          @id @default(uuid())
  name      String
  slug      String          @unique
  status    WorkspaceStatus @default(ACTIVE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  members           WorkspaceMember[]
  invitations       WorkspaceInvitation[]
  allowedDomains    WorkspaceAllowedDomain[]
  apiKeys           ApiKey[]
  documents         Document[]
  documentChunks    DocumentChunk[]
  conversations     Conversation[]
  messages          Message[]
  notes             ConversationNote[]
  auditLogs         ConversationAuditLog[]
  feedbacks         ConversationFeedback[]
  aiTraces          AIResponseTrace[]
  subscriptions     Subscription[]
  usageRecords      WorkspaceUsage[]
  fcmTokens         AgentFcmToken[]
  webhookEndpoints  WebhookEndpoint[]
  webhookDeliveries WebhookDelivery[]

  @@index([slug])
  @@index([status])
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(AGENT)
  status      MemberStatus  @default(ACTIVE)
  joinedAt    DateTime?
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model WorkspaceInvitation {
  id          String           @id @default(uuid())
  workspaceId String
  invitedById String
  email       String
  role        WorkspaceRole
  tokenHash   String
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([invitedById])
  @@index([tokenHash])
}

model WorkspaceAllowedDomain {
  id          String   @id @default(uuid())
  workspaceId String
  domain      String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, domain])
  @@index([workspaceId])
}

model ApiKey {
  id          String       @id @default(uuid())
  workspaceId String
  createdById String
  name        String
  keyHash     String       @unique
  keyPrefix   String
  status      ApiKeyStatus @default(ACTIVE)
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime     @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([createdById])
  @@index([keyPrefix])
  @@index([status])
}

model Document {
  id           String         @id @default(uuid())
  workspaceId  String
  uploadedById String
  fileName     String
  storageKey   String
  mimeType     String
  sizeBytes    Int?
  status       DocumentStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  workspace  Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploadedBy User            @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  chunks     DocumentChunk[]

  @@index([workspaceId])
  @@index([uploadedById])
  @@index([status])
}

model DocumentChunk {
  id          String                 @id @default(uuid())
  documentId  String
  workspaceId String
  chunkIndex  Int
  content     String
  embedding   Unsupported("vector")?
  createdAt   DateTime               @default(now())

  document  Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  sourceMessages MessageSourceChunk[]

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@index([workspaceId])
}

model Conversation {
  id              String             @id @default(uuid())
  workspaceId     String
  assignedAgentId String?
  customerName    String?
  customerEmail   String?
  visitorId       String?
  sessionId       String?
  status          ConversationStatus @default(OPEN)
  source          ConversationSource @default(WIDGET)
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedAgent User?     @relation(fields: [assignedAgentId], references: [id], onDelete: SetNull)

  messages  Message[]
  notes     ConversationNote[]
  auditLogs ConversationAuditLog[]
  feedback  ConversationFeedback?

  @@index([workspaceId])
  @@index([assignedAgentId])
  @@index([status])
  @@index([visitorId])
  @@index([sessionId])
}

model Message {
  id             String     @id @default(uuid())
  conversationId String
  workspaceId    String
  senderUserId   String?
  senderType     SenderType
  content        String
  metadata       Json?
  createdAt      DateTime   @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  senderUser   User?        @relation(fields: [senderUserId], references: [id], onDelete: SetNull)

  aiTrace      AIResponseTrace?
  sourceChunks MessageSourceChunk[]

  @@index([conversationId])
  @@index([workspaceId])
  @@index([senderUserId])
  @@index([senderType])
}

model ConversationNote {
  id             String   @id @default(uuid())
  conversationId String
  workspaceId    String
  authorId       String
  note           String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([workspaceId])
  @@index([authorId])
}

model ConversationAuditLog {
  id             String   @id @default(uuid())
  conversationId String
  workspaceId    String
  actorUserId    String?
  action         String
  oldValue       String?
  newValue       String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorUser    User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([workspaceId])
  @@index([actorUserId])
  @@index([action])
}

model ConversationFeedback {
  id             String   @id @default(uuid())
  conversationId String   @unique
  workspaceId    String
  rating         Int
  comment        String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model AIResponseTrace {
  id               String   @id @default(uuid())
  messageId        String   @unique
  workspaceId      String
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  confidenceScore  Float?
  latencyMs        Int?
  createdAt        DateTime @default(now())

  message   Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([model])
}

model MessageSourceChunk {
  id              String   @id @default(uuid())
  messageId       String
  chunkId         String
  similarityScore Float?
  createdAt       DateTime @default(now())

  message Message       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  chunk   DocumentChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@unique([messageId, chunkId])
  @@index([messageId])
  @@index([chunkId])
}

model Subscription {
  id                   String             @id @default(uuid())
  workspaceId          String
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([stripeCustomerId])
  @@index([status])
}

model WorkspaceUsage {
  id               String   @id @default(uuid())
  workspaceId      String
  usageDate        DateTime
  messagesCount    Int      @default(0)
  aiRequestsCount  Int      @default(0)
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  documentsCount   Int      @default(0)
  createdAt        DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, usageDate])
  @@index([workspaceId])
  @@index([usageDate])
}

model AgentFcmToken {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  token       String   @unique
  deviceType  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
}

model WebhookEndpoint {
  id          String        @id @default(uuid())
  workspaceId String
  url         String
  secret      String
  status      WebhookStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace  Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([workspaceId])
  @@index([status])
}

model WebhookDelivery {
  id             String                @id @default(uuid())
  workspaceId    String
  endpointId     String
  eventType      String
  payload        Json
  status         WebhookDeliveryStatus @default(PENDING)
  attempts       Int                   @default(0)
  responseStatus Int?
  errorMessage   String?
  nextAttemptAt  DateTime?
  createdAt      DateTime              @default(now())

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  endpoint  WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([endpointId])
  @@index([status])
  @@index([nextAttemptAt])
}
